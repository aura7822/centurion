# AI Service API Keys
AZURE_FACE_API_KEY=your_azure_key_here
AZURE_FACE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
GOOGLE_VISION_API_KEY=your_google_key
KAIROS_API_KEY=your_kairos_key

# Blockchain API Keys
ALCHEMY_API_KEY=your_alchemy_key
INFURA_PROJECT_ID=your_infura_id
ETHEREUM_PRIVATE_KEY=your_private_key

# Threat Intelligence APIs
VIRUSTOTAL_API_KEY=your_virustotal_key
HAVEIBEENPWNED_API_KEY=your_hibp_key
SPYCLOUD_API_KEY=your_spycloud_key

# Security Settings
ENCRYPTION_SECRET=your-32-char-encryption-secret-here
JWT_SECRET=your-jwt-secret-here

# Tor Configuration
TOR_ENABLED=true
TOR_SOCKS5_PROXY=127.0.0.1:9050
